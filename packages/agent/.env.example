# AI Agent Configuration
# Copy this file to .env and fill in your actual values

# LLM Provider Configuration
# Supported providers: google, openai, anthropic, llamastack
LLM_PROVIDER=llamastack
LLM_MODEL=meta-llama/Llama-3.2-3B-Instruct
LLM_API_KEY=your-api-key-here

# MCP (Model Context Protocol) Configuration
# Set to true to enable MCP tool integration
MCP_ENABLED=false
# MCP_SSE_URL=http://localhost:3001/sse

# LlamaStack Configuration
# LLAMASTACK_URL=http://localhost:8321/v1

# Checkpoint Storage
# Set DATABASE_URL to enable PostgreSQL checkpoint persistence
# When unset, uses in-memory storage (conversations lost on restart)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/myapp
