# Environment Variables
# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# Database Configuration
POSTGRES_DB=dagshub-ai-dev-plaform-support
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://user:changeme@localhost:5432/dagshub-ai-dev-plaform-support
DB_ECHO=false

# API Configuration
DEBUG=true
ALLOWED_HOSTS=["http://localhost:5173"]

# UI Configuration
VITE_API_BASE_URL=http://localhost:8000
VITE_ENVIRONMENT=development

# AI Agent Configuration
LLM_PROVIDER=llamastack
LLM_MODEL=meta-llama/Llama-3.2-3B-Instruct
LLM_API_KEY=your-api-key-here
MCP_ENABLED=true
MCP_SSE_URL=http://localhost:3001/sse
LLAMASTACK_URL=http://localhost:8321/v1

# MCP Server Configuration
MCP_HOST=0.0.0.0
MCP_PORT=3000
MCP_TRANSPORT_PROTOCOL=sse

# OpenShift/Deployment Configuration
# These are used by make deploy
# REGISTRY_URL is auto-detected from oc registry info if not set
# REGISTRY_URL=default-route-openshift-image-registry.apps.example.com
NAMESPACE=dagshub-ai-dev-plaform-support
IMAGE_TAG=latest
